{
  "name": "@dkships/pm-copilot",
  "version": "1.0.0",
  "description": "MCP server that triangulates customer support tickets and feature requests to help PMs decide what to build next",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pm-copilot": "dist/index.js"
  },
  "files": [
    "dist",
    "themes.config.json",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "prepublishOnly": "npm run build && npm test && npm run audit:ci"
  },
  "keywords": [
    "mcp",
    "product-management",
    "helpscout",
    "productlift",
    "customer-feedback",
    "prioritization"
  ],
  "license": "MIT",
  "author": "David Kelly <contact@dmkthinks.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkships/pm-copilot.git"
  },
  "bugs": {
    "url": "https://github.com/dkships/pm-copilot/issues"
  },
  "homepage": "https://github.com/dkships/pm-copilot#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
